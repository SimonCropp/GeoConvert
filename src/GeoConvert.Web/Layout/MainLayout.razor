@inherits LayoutComponentBase
@inject ThemePreferenceService ThemePreferenceService
@inject IJSRuntime JSRuntime

@code {
    ThemeType currentTheme = ThemeType.Light;
    string? userAgent;

    protected override async Task OnInitializedAsync()
    {
        currentTheme = await ThemePreferenceService.GetSavedThemeAsync();
        await JSRuntime.InvokeVoidAsync("themeManager.applyTheme", currentTheme.ToString());
        userAgent = await JSRuntime.InvokeAsync<string?>("appInfo.userAgent");
    }

    async Task HandleThemeChanged(ThemeType newTheme)
    {
        currentTheme = newTheme;
        await ThemePreferenceService.SaveThemeAsync(newTheme);
        await JSRuntime.InvokeVoidAsync("themeManager.applyTheme", newTheme.ToString());
    }
}

<header>
    <h1>GeoConvert</h1>
    <p>Convert maps between GeoJSON, TopoJSON, FlatGeobuf, KML/KMZ, GPX, WKT, WKB, CSV and GeoParquet — entirely in your browser</p>
    <ThemeToggle CurrentTheme="currentTheme" OnThemeChanged="HandleThemeChanged" />
</header>

<div class="container">
    <ErrorBoundary>
        <ChildContent>
            @Body
        </ChildContent>
        <ErrorContent Context="exception">
            <ErrorPanel Message="@($"Something went wrong: {exception.Message}")"
                        IssueUrl="@IssueLauncher.ForException("Unhandled error", exception, AppInfo.Environment(userAgent))" />
        </ErrorContent>
    </ErrorBoundary>
</div>

<footer>
    <p>Powered by <a href="https://github.com/Papyrine/GeoConvert" target="_blank">GeoConvert</a> — no data leaves your device</p>
</footer>
