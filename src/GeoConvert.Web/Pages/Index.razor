@page "/"
@inject FileDownloadService FileDownloadService
@inject IJSRuntime JsRuntime

<PageTitle>GeoConvert — Map Format Converter</PageTitle>

<div class="converter">
    <div class="upload-panel">
        <label class="file-drop" for="map-file">
            <span class="file-drop-icon">🗺️</span>
            <span class="file-drop-text">
                @if (sourceName is null)
                {
                    <strong>Choose a map file</strong>
                    <span>GeoJSON, TopoJSON, FlatGeobuf, KML, KMZ, GPX, WKT, WKB, CSV or GeoParquet</span>
                }
                else
                {
                    <strong>@sourceName</strong>
                    <span>@sourceFormat?.DisplayName · @featureCount feature@(featureCount == 1 ? "" : "s")</span>
                }
            </span>
            <InputFile id="map-file" OnChange="OnFileSelected" class="file-input" />
        </label>
    </div>

    @if (errorMessage is not null)
    {
        <ErrorPanel Message="@errorMessage" IssueUrl="@issueUrl" />
    }

    @* The read phase happens before the convert panel exists, so its progress shows here. The render
       preview shows its bar in the preview slot, and the download (write/render) shows its bar under the
       Download button — each next to the action that triggered it. Reading is indeterminate: the
       uploaded file is already in memory, so its byte fraction hits 100% instantly and the real work
       (parsing, building features) carries on behind it — an animated bar shows that's still happening. *@
    @if (isBusy && !isRendering && features is null)
    {
        <ConversionProgress Label="@progressLabel" Report="progressReport" Indeterminate="true" />
    }

    @if (features is not null)
    {
        @if (isRendering || previewDataUrl is not null)
        {
            <div class="preview">
                @if (isRendering)
                {
                    <div class="preview-busy">
                        <ConversionProgress Label="@progressLabel" Report="progressReport" />
                    </div>
                }
                else
                {
                    <img src="@previewDataUrl" alt="Rendered preview of the uploaded map" />
                }
            </div>
        }

        @if (previewDataUrl is not null)
        {
            <div class="image-options">
                <div class="format-selector">
                    <label for="projection-select">Map projection</label>
                    <select id="projection-select" class="format-select" value="@projection" @onchange="OnProjectionChanged">
                        @foreach (var option in Projections)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
                <div class="format-selector">
                    <label for="max-dimension">Max dimension</label>
                    <select id="max-dimension" class="format-select" value="@maxDimension" @onchange="OnMaxDimensionChanged">
                        @foreach (var option in Dimensions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
            </div>
        }

        <div class="convert-panel">
            <FormatSelector Label="Convert to"
                            Formats="ConversionService.WritableFormats"
                            Selected="target"
                            SelectedChanged="OnTargetChanged" />
            <button class="convert-btn" @onclick="Download" disabled="@(features.Count == 0 || isBusy)">
                @if (isBusy)
                {
                    <span class="btn-spinner"></span>
                }
                Download @TargetInfo?.DisplayName
            </button>
        </div>

        @* Clicking Download runs the actual conversion (write, or render for PNG) on a background
           thread; show its live progress right under the button. !isRendering excludes the preview
           render, which has its own bar above. *@
        @if (isBusy && !isRendering)
        {
            <ConversionProgress Label="@progressLabel" Report="progressReport" />
        }
    }
</div>

@code {
    const long MaxFileSize = 50 * 1024 * 1024;

    static readonly (MapProjection Value, string Label)[] Projections =
    [
        (MapProjection.Auto, "Automatic"),
        (MapProjection.PlateCarree, "Plate Carrée"),
        (MapProjection.WebMercator, "Web Mercator"),
        (MapProjection.Lambert, "Lambert Conformal Conic"),
        (MapProjection.Goode, "Goode Homolosine"),
    ];

    static readonly (int Value, string Label)[] Dimensions =
    [
        (512, "512 px"),
        (1024, "1024 px"),
        (2048, "2048 px"),
        (4096, "4096 px"),
        (8192, "8192 px"),
    ];

    byte[]? sourceBytes;
    string? sourceName;
    FormatInfo? sourceFormat;
    FeatureCollection? features;
    int featureCount;
    string? previewDataUrl;
    string? errorMessage;
    string? issueUrl;
    string? userAgent;
    GeoFormat target = GeoFormat.Kml;
    MapProjection projection = MapProjection.Auto;
    int maxDimension = 2048;
    bool isBusy;
    bool isRendering;
    ConvertProgress? progressReport;
    string? progressLabel;
    IProgress<ConvertProgress>? progress;
    ProgressPhase? lastPhase;
    long lastRepaintTick;

    // Min gap between progress repaints. Time- rather than percent-based so the count keeps climbing even
    // when the fraction is pinned (e.g. a buffered read whose byte fraction sits at 100% while features
    // build), while still capping renders at ~16/sec for a feature-by-feature stream.
    const long RepaintIntervalMs = 60;

    FormatInfo? TargetInfo => ConversionService.Find(target);

    protected override async Task OnInitializedAsync()
    {
        // Conversions run on a background thread (Task.Run), and Progress<T> marshals each report back
        // to this UI thread via the captured synchronization context — so StateHasChanged below repaints
        // the bar live while the worker crunches. Constructed here so it captures the UI context.
        progress = new Progress<ConvertProgress>(OnProgressReport);
        userAgent = await JsRuntime.InvokeAsync<string?>("appInfo.userAgent");
    }

    void OnProgressReport(ConvertProgress report)
    {
        progressReport = report;
        var now = Environment.TickCount64;
        // Always repaint on a phase change; otherwise rate-limit so a feature-by-feature stream doesn't
        // queue thousands of renders.
        if (report.Phase == lastPhase && now - lastRepaintTick < RepaintIntervalMs)
        {
            return;
        }

        lastPhase = report.Phase;
        lastRepaintTick = now;
        StateHasChanged();
    }

    // Switches the visible phase and resets the throttle so the next report repaints immediately. No
    // paint hack needed: the heavy work runs off-thread, so the UI thread stays free to paint this and
    // every progress update.
    void BeginPhase(string label)
    {
        progressLabel = label;
        progressReport = null;
        lastPhase = null;
        lastRepaintTick = 0;
        isBusy = true;
        StateHasChanged();
    }

    async Task OnFileSelected(InputFileChangeEventArgs args)
    {
        Reset();

        var file = args.File;
        sourceName = file.Name;

        var detected = ConversionService.DetectReadable(file.Name);
        if (detected is null)
        {
            // User error rather than a bug, so no "report an issue" prompt.
            errorMessage = $"Can't read '{file.Name}'. Upload a GeoJSON, TopoJSON, FlatGeobuf, KML, KMZ, GPX, WKT, WKB, CSV or GeoParquet file.";
            return;
        }

        sourceFormat = detected;

        try
        {
            using var stream = file.OpenReadStream(MaxFileSize);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            var bytes = memory.ToArray();
            sourceBytes = bytes;

            BeginPhase("Reading map…");
            features = await Task.Run(() => ConversionService.Read(bytes, detected.Format, progress));
            featureCount = features.Count;
            await RefreshPreviewAsync();
        }
        catch (Exception exception)
        {
            ReportError("Could not read the map", exception);
            features = null;
        }
        finally
        {
            isBusy = false;
        }
    }

    // Rendering a large map is CPU-bound. With the multithreaded runtime it runs on a background thread
    // (Task.Run), keeping the UI thread free to paint the progress bar live as features are rasterised.
    async Task RefreshPreviewAsync()
    {
        if (features is not { Count: > 0 } collection)
        {
            previewDataUrl = null;
            return;
        }

        isRendering = true;
        BeginPhase("Rendering preview…");
        try
        {
            previewDataUrl = await Task.Run(() => RenderPreview(collection));
        }
        finally
        {
            isBusy = false;
            isRendering = false;
        }
    }

    string? RenderPreview(FeatureCollection collection)
    {
        try
        {
            var png = ConversionService.RenderPng(collection, projection, maxDimension, progress);
            return $"data:image/png;base64,{Convert.ToBase64String(png)}";
        }
        catch
        {
            // Preview is best-effort; an unrenderable map (e.g. no spatial extent) just shows no image.
            return null;
        }
    }

    Task OnTargetChanged(GeoFormat format)
    {
        target = format;
        return Task.CompletedTask;
    }

    Task OnProjectionChanged(ChangeEventArgs args)
    {
        projection = Enum.Parse<MapProjection>((string) args.Value!);
        return RefreshPreviewAsync();
    }

    Task OnMaxDimensionChanged(ChangeEventArgs args)
    {
        if (int.TryParse((string?) args.Value, out var value) && value > 0)
        {
            maxDimension = value;
        }

        return RefreshPreviewAsync();
    }

    async Task Download()
    {
        if (features is not { } collection || sourceFormat is null)
        {
            return;
        }

        var info = TargetInfo;
        if (info is null)
        {
            return;
        }

        BeginPhase(info.Format == GeoFormat.Png
            ? "Rendering image…"
            : $"Writing {info.DisplayName}…");
        try
        {
            var format = info.Format;
            var bytes = await Task.Run(() => format == GeoFormat.Png
                ? ConversionService.RenderPng(collection, projection, maxDimension, progress)
                : ConversionService.Write(collection, format, progress));
            var baseName = Path.GetFileNameWithoutExtension(sourceName) ?? "map";
            await FileDownloadService.DownloadAsync($"{baseName}{info.Extension}", info.ContentType, bytes);
        }
        catch (Exception exception)
        {
            ReportError($"Could not convert to {info.DisplayName}", exception);
        }
        finally
        {
            isBusy = false;
        }
    }

    void ReportError(string action, Exception exception)
    {
        errorMessage = $"{action}: {exception.Message}";
        issueUrl = IssueLauncher.ForException(action, exception, AppInfo.Environment(userAgent));
    }

    void Reset()
    {
        errorMessage = null;
        issueUrl = null;
        sourceBytes = null;
        sourceName = null;
        sourceFormat = null;
        features = null;
        featureCount = 0;
        previewDataUrl = null;
        isBusy = false;
        isRendering = false;
        progressReport = null;
        progressLabel = null;
    }
}
