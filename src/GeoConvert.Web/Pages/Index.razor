@page "/"
@inject FileDownloadService FileDownloadService
@inject IJSRuntime JsRuntime

<PageTitle>GeoConvert — Map Format Converter</PageTitle>

<div class="converter">
    <div class="upload-panel">
        <label class="file-drop" for="map-file">
            <span class="file-drop-icon">🗺️</span>
            <span class="file-drop-text">
                @if (sourceName is null)
                {
                    <strong>Choose a map file</strong>
                    <span>GeoJSON, TopoJSON, FlatGeobuf, KML, KMZ, GPX, WKT, WKB, CSV or GeoParquet</span>
                }
                else
                {
                    <strong>@sourceName</strong>
                    <span>@sourceFormat?.DisplayName · @featureCount feature@(featureCount == 1 ? "" : "s")</span>
                }
            </span>
            <InputFile id="map-file" OnChange="OnFileSelected" class="file-input" />
        </label>
    </div>

    @if (errorMessage is not null)
    {
        <ErrorPanel Message="@errorMessage" IssueUrl="@issueUrl" />
    }

    @if (features is not null)
    {
        @if (isRendering || previewDataUrl is not null)
        {
            <div class="preview">
                @if (isRendering)
                {
                    <div class="preview-busy">
                        <div class="spinner"></div>
                    </div>
                }
                else
                {
                    <img src="@previewDataUrl" alt="Rendered preview of the uploaded map" />
                }
            </div>
        }

        @if (previewDataUrl is not null)
        {
            <div class="image-options">
                <div class="format-selector">
                    <label for="projection-select">Map projection</label>
                    <select id="projection-select" class="format-select" value="@projection" @onchange="OnProjectionChanged">
                        @foreach (var option in Projections)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
                <div class="format-selector">
                    <label for="max-dimension">Max dimension</label>
                    <select id="max-dimension" class="format-select" value="@maxDimension" @onchange="OnMaxDimensionChanged">
                        @foreach (var option in Dimensions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
            </div>
        }

        <div class="convert-panel">
            <FormatSelector Label="Convert to"
                            Formats="ConversionService.WritableFormats"
                            Selected="target"
                            SelectedChanged="OnTargetChanged" />
            <button class="convert-btn" @onclick="Download" disabled="@(features.Count == 0 || isBusy)">
                @if (isBusy)
                {
                    <span class="btn-spinner"></span>
                }
                Download @TargetInfo?.DisplayName
            </button>
        </div>
    }
</div>

@code {
    const long MaxFileSize = 50 * 1024 * 1024;

    static readonly (MapProjection Value, string Label)[] Projections =
    [
        (MapProjection.Auto, "Automatic"),
        (MapProjection.PlateCarree, "Plate Carrée"),
        (MapProjection.WebMercator, "Web Mercator"),
        (MapProjection.Lambert, "Lambert Conformal Conic"),
        (MapProjection.Goode, "Goode Homolosine"),
    ];

    static readonly (int Value, string Label)[] Dimensions =
    [
        (512, "512 px"),
        (1024, "1024 px"),
        (2048, "2048 px"),
        (4096, "4096 px"),
        (8192, "8192 px"),
    ];

    byte[]? sourceBytes;
    string? sourceName;
    FormatInfo? sourceFormat;
    FeatureCollection? features;
    int featureCount;
    string? previewDataUrl;
    string? errorMessage;
    string? issueUrl;
    string? userAgent;
    GeoFormat target = GeoFormat.Kml;
    MapProjection projection = MapProjection.Auto;
    int maxDimension = 2048;
    bool isBusy;
    bool isRendering;

    FormatInfo? TargetInfo => ConversionService.Find(target);

    protected override async Task OnInitializedAsync() =>
        userAgent = await JsRuntime.InvokeAsync<string?>("appInfo.userAgent");

    async Task OnFileSelected(InputFileChangeEventArgs args)
    {
        Reset();

        var file = args.File;
        sourceName = file.Name;

        var detected = ConversionService.DetectReadable(file.Name);
        if (detected is null)
        {
            // User error rather than a bug, so no "report an issue" prompt.
            errorMessage = $"Can't read '{file.Name}'. Upload a GeoJSON, TopoJSON, FlatGeobuf, KML, KMZ, GPX, WKT, WKB, CSV or GeoParquet file.";
            return;
        }

        sourceFormat = detected;

        try
        {
            using var stream = file.OpenReadStream(MaxFileSize);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            sourceBytes = memory.ToArray();

            features = ConversionService.Read(sourceBytes, detected.Format);
            featureCount = features.Count;
            await RefreshPreviewAsync();
        }
        catch (Exception exception)
        {
            ReportError("Could not read the map", exception);
            features = null;
        }
    }

    // Rendering a large map is CPU-bound and synchronous on the WASM thread, so it freezes the UI.
    // Flip the busy flag, then wait for the browser to actually paint the spinner (appInfo.paintThen)
    // before the blocking render, so the user sees progress instead of a stalled page. A bare
    // Task.Delay(1) flushes the DOM but the render starts before the spinner frame is composited.
    async Task RefreshPreviewAsync()
    {
        if (features is null || features.Count == 0)
        {
            previewDataUrl = null;
            return;
        }

        isBusy = true;
        isRendering = true;
        StateHasChanged();
        await JsRuntime.InvokeVoidAsync("appInfo.paintThen");
        try
        {
            previewDataUrl = RenderPreview(features);
        }
        finally
        {
            isBusy = false;
            isRendering = false;
        }
    }

    string? RenderPreview(FeatureCollection collection)
    {
        try
        {
            var png = ConversionService.RenderPng(collection, projection, maxDimension);
            return $"data:image/png;base64,{Convert.ToBase64String(png)}";
        }
        catch
        {
            // Preview is best-effort; an unrenderable map (e.g. no spatial extent) just shows no image.
            return null;
        }
    }

    Task OnTargetChanged(GeoFormat format)
    {
        target = format;
        return Task.CompletedTask;
    }

    async Task OnProjectionChanged(ChangeEventArgs args)
    {
        projection = Enum.Parse<MapProjection>((string) args.Value!);
        await RefreshPreviewAsync();
    }

    async Task OnMaxDimensionChanged(ChangeEventArgs args)
    {
        if (int.TryParse((string?) args.Value, out var value) && value > 0)
        {
            maxDimension = value;
        }

        await RefreshPreviewAsync();
    }

    async Task Download()
    {
        if (features is null || sourceFormat is null)
        {
            return;
        }

        var info = TargetInfo;
        if (info is null)
        {
            return;
        }

        isBusy = true;
        StateHasChanged();
        await JsRuntime.InvokeVoidAsync("appInfo.paintThen");
        try
        {
            var bytes = info.Format == GeoFormat.Png
                ? ConversionService.RenderPng(features, projection, maxDimension)
                : ConversionService.Write(features, info.Format);
            var baseName = Path.GetFileNameWithoutExtension(sourceName) ?? "map";
            await FileDownloadService.DownloadAsync($"{baseName}{info.Extension}", info.ContentType, bytes);
        }
        catch (Exception exception)
        {
            ReportError($"Could not convert to {info.DisplayName}", exception);
        }
        finally
        {
            isBusy = false;
        }
    }

    void ReportError(string action, Exception exception)
    {
        errorMessage = $"{action}: {exception.Message}";
        issueUrl = IssueLauncher.ForException(action, exception, AppInfo.Environment(userAgent));
    }

    void Reset()
    {
        errorMessage = null;
        issueUrl = null;
        sourceBytes = null;
        sourceName = null;
        sourceFormat = null;
        features = null;
        featureCount = 0;
        previewDataUrl = null;
        isBusy = false;
        isRendering = false;
    }
}
